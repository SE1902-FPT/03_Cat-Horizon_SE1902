  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Trong m\u1ED9t th\u1EBF gi\u1EDBi t\u01B0\u01A1ng lai, m\u1ED9t nh\xF3m
    robot ngo\xE0i h\xE0nh tinh b\u1EA5t ng\u1EDD x\xE2m chi\u1EBFm Tr\xE1i \u0110\u1EA5t
    v\xE0 chi\u1EBFm quy\u1EC1n ki\u1EC3m so\xE1t nhi\u1EC1u th\xE0nh ph\u1ED1. Th\u1EBF
    gi\u1EDBi r\u01A1i v\xE0o h\u1ED7n lo\u1EA1n khi con ng\u01B0\u1EDDi kh\xF4ng
    th\u1EC3 ch\u1ED1ng l\u1EA1i c\xF4ng ngh\u1EC7 m\u1EA1nh m\u1EBD c\u1EE7a ch\xFAng.\n\nM\u1ED9t
    ng\xE0y n\u1ECD, m\u1ED9t ch\xFA m\xE8o v\xF4 t\xECnh ti\u1EBFp x\xFAc v\u1EDBi
    ngu\u1ED3n n\u0103ng l\u01B0\u1EE3ng v\u0169 tr\u1EE5 b\xED \u1EA9n t\u1EEB m\u1ED9t
    thi\xEAn th\u1EA1ch r\u01A1i xu\u1ED1ng. Ngu\u1ED3n n\u0103ng l\u01B0\u1EE3ng
    n\xE0y mang l\u1EA1i cho ch\xFA m\xE8o m\u1ED9t kh\u1EA3 n\u0103ng \u0111\u1EB7c
    bi\u1EC7t: b\u1EAFn ra nh\u1EEFng tia laser m\u1EA1nh m\u1EBD.\n\nV\u1EDBi s\u1EE9c
    m\u1EA1nh m\u1EDBi n\xE0y, ch\xFA m\xE8o tr\u1EDF th\xE0nh Horizon Cat, ng\u01B0\u1EDDi
    h\xF9ng duy nh\u1EA5t c\xF3 th\u1EC3 ch\u1ED1ng l\u1EA1i cu\u1ED9c x\xE2m l\u01B0\u1EE3c
    c\u1EE7a ng\u01B0\u1EDDi ngo\xE0i h\xE0nh tinh.\n\nNg\u01B0\u1EDDi ch\u01A1i
    s\u1EBD \u0111i\u1EC1u khi\u1EC3n Horizon Cat v\u01B0\u1EE3t qua nhi\u1EC1u khu
    v\u1EF1c nguy hi\u1EC3m, \u0111\xE1nh b\u1EA1i k\u1EBB th\xF9 ngo\xE0i h\xE0nh
    tinh v\xE0 ng\u0103n ch\u1EB7n cu\u1ED9c x\xE2m l\u01B0\u1EE3c \u0111\u1EC3 mang
    l\u1EA1i h\xF2a b\xECnh cho th\u1EBF gi\u1EDBi."
